# -------------------------------------------------------------
# Sentinal System - Environment Variables Template
# -------------------------------------------------------------
# Instructions:
# 1. Copy this file and rename it to `.env`
# 2. Update the values with your actual production secrets securely
# 3. DO NOT COMMIT the `.env` file to version control.
# -------------------------------------------------------------

# --- Database Credentials ---
POSTGRES_USER=user
POSTGRES_PASSWORD=your_secure_postgres_password_here

# --- Grafana Config ---
GF_SECURITY_ADMIN_PASSWORD=your_secure_grafana_password_here

# --- Spring Boot Postgres Connection ---
# Make sure to update the user and password in the URL if needed, or rely on properties
DB_USERNAME=user
DB_PASSWORD=your_secure_postgres_password_here
DB_URL=jdbc:postgresql://localhost:5432/sentinel_db

# --- Security & Auth (Spring Boot) ---
JWT_SECRET=your_secure_base64_encoded_jwt_secret_here_replace_me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# --- Infrastructure Hosts (Spring Boot) ---
# Override if deploying services across different hosts in production
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
